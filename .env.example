# fbchat-v2 environment template
# Copy this file to `.env` and fill real values locally.
# Do not commit `.env` or any real Facebook cookie/password/token.

# Cookie/session based flows
# Full Facebook cookie string used by local tests/scripts that read env directly.
FB_COOKIE="c_user=...; xs=...; fr=...; datr=...;"

# Cookie string used by E2EE smoke-test helpers.
FBCHAT_COOKIE="c_user=...; xs=...; fr=...; datr=...;"

# Optional generic session storage env var for EnvSessionStorage().
FB_COOKIES="c_user=...; xs=...; fr=...; datr=...;"

# Credential login flow
# Optional FB4A overrides. Leave empty to use the built-in legacy FB4A defaults.
FBCHAT_APP_ACCESS_TOKEN=""
FBCHAT_API_KEY=""

# Only needed when running src/_core/_facebookLogin.py directly.
FBCHAT_USER=""
FBCHAT_PASS=""
FBCHAT_2FA=""

# Attachment upload local test helper
# Leave empty to let test_script.py create/use its temporary sample file.
FBCHAT_ATTACHMENT_FILE=""

# E2EE bridge
# Optional path to a verified fbchat-bridge-e2ee binary.
FBCHAT_E2EE_BIN=""
